<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eco_bg">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="50dp"
        android:paddingBottom="50dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_leaf"
            app:tint="@color/eco_green" />

        <!-- Título -->
        <TextView
            android:text="Crear cuenta"
            android:textColor="@color/eco_text_dark"
            android:textStyle="bold"
            android:textSize="32sp"
            android:layout_marginBottom="40dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Card principal -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="22dp"
            app:cardElevation="2dp"
            android:backgroundTint="@color/eco_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Campo nombre -->
                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:drawableLeft="@drawable/ic_user"
                    android:drawablePadding="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:hint="Nombre completo"
                    android:textColorHint="@color/eco_text_dark"
                    android:textSize="16sp" />

                <!-- Campo email -->
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:drawableLeft="@drawable/ic_email"
                    android:drawablePadding="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:hint="Correo electrónico"
                    android:inputType="textEmailAddress"
                    android:textColorHint="@color/eco_text_dark"
                    android:textSize="16sp" />

                <!-- Campo password -->
                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:drawableLeft="@drawable/ic_lock"
                    android:drawablePadding="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:textColorHint="@color/eco_text_dark"
                    android:textSize="16sp" />

                <!-- Botón Registrar -->
                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/eco_green"
                    android:text="Registrar"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Texto para volver al login -->
        <TextView
            android:id="@+id/tvGoLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="¿Ya tienes cuenta? Inicia sesión aquí"
            android:textColor="@color/eco_text_dark"
            android:textSize="14sp"
            android:textAlignment="center"/>

    </LinearLayout>
</ScrollView>
