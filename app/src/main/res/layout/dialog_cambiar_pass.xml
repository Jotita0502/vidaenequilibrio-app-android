<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:background="@drawable/bg_modal"
    android:orientation="vertical">

    <TextView
        android:text="Cambiar Contraseña"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/eco_text_dark"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/edtPassActual"
        android:hint="Contraseña actual"
        android:inputType="textPassword"
        android:background="@drawable/bg_edittext"
        android:padding="12dp"
        android:layout_marginBottom="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/edtPassNueva"
        android:hint="Nueva contraseña"
        android:inputType="textPassword"
        android:background="@drawable/bg_edittext"
        android:padding="12dp"
        android:layout_marginBottom="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/edtPassConfirmar"
        android:hint="Confirmar contraseña"
        android:inputType="textPassword"
        android:background="@drawable/bg_edittext"
        android:padding="12dp"
        android:layout_marginBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnGuardarPass"
        android:text="Guardar"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/eco_blue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
